{
  "name": "@circuit/wallet",
  "version": "0.0.0",
  "description": "Circuit SDK wallet — SOL/CIRC balances, transfers, and Jupiter swaps. Implements @circuit/x402's PaymentWallet.",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --conditions=development --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "dependencies": {
    "@circuit/core": "0.0.0",
    "@circuit/x402": "0.0.0",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.14",
    "bs58": "^6.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
