{
  "name": "@circuit-llm/models",
  "version": "0.2.7",
  "description": "Circuit SDK models — client for the circuitllm.xyz/models gateway: buy prepaid credits in USDC/SOL/CIRC, mint a Circuit API key, and call the metered OpenAI-compatible chat API.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --conditions=development --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "dependencies": {
    "@circuit-llm/core": "0.2.7",
    "@circuit-llm/wallet": "0.2.7"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Circuit-LLM/circuit-sdk.git",
    "directory": "packages/models"
  },
  "homepage": "https://github.com/Circuit-LLM/circuit-sdk/tree/main/packages/models#readme",
  "bugs": {
    "url": "https://github.com/Circuit-LLM/circuit-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
