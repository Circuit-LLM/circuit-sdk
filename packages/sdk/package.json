{
  "name": "@circuit-llm/sdk",
  "version": "0.2.1",
  "description": "Circuit SDK — batteries-included meta-package re-exporting @circuit-llm/{core,x402,inference,data,wallet}.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --conditions=development --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "dependencies": {
    "@circuit-llm/core": "0.2.1",
    "@circuit-llm/x402": "0.2.1",
    "@circuit-llm/inference": "0.2.1",
    "@circuit-llm/data": "0.2.1",
    "@circuit-llm/wallet": "0.2.1",
    "@circuit-llm/agent": "0.2.1",
    "@circuit-llm/node": "0.2.1",
    "@circuit-llm/onchain": "0.2.1",
    "@circuit-llm/attest": "0.2.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Circuit-LLM/circuit-sdk.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Circuit-LLM/circuit-sdk/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/Circuit-LLM/circuit-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
