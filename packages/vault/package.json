{
  "name": "@circuit-llm/vault",
  "version": "0.2.6",
  "description": "Circuit SDK vault client \u2014 drive the non-custodial on-chain Agent Vault Anchor program: owner lifecycle, the route-agnostic trade adapter, a Jupiter route source, and makeVaultExecutor (the concrete executor for @circuit-llm/agent's VaultCustody). Opt-in: pulls @anchor-lang/core.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --conditions=development --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "peerDependencies": {
    "@anchor-lang/core": "^1.1.1"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.1.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Circuit-LLM/circuit-sdk.git",
    "directory": "packages/vault"
  },
  "homepage": "https://github.com/Circuit-LLM/circuit-sdk/tree/main/packages/vault#readme",
  "bugs": {
    "url": "https://github.com/Circuit-LLM/circuit-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
