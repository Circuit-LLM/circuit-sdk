{
  "name": "@circuit-llm/attest",
  "version": "0.2.6",
  "description": "Circuit SDK attestation \u2014 the verified-intent core: sign/verify authenticated inputs (signed first-party data, inference receipts, zkTLS), a safe decision-rule DSL, and the signer-side decision gate that re-derives a trade and rejects forgeries. Shared by the agent and the signer.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --conditions=development --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "dependencies": {
    "@circuit-llm/core": "0.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Circuit-LLM/circuit-sdk.git",
    "directory": "packages/attest"
  },
  "homepage": "https://github.com/Circuit-LLM/circuit-sdk/tree/main/packages/attest#readme",
  "bugs": {
    "url": "https://github.com/Circuit-LLM/circuit-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
