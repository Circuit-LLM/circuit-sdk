{
  "name": "@circuit/data",
  "version": "0.0.0",
  "description": "Circuit SDK data — typed client for the Circuit Data API (market + on-chain data), paid per call in CIRC (x402).",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --conditions=development --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "dependencies": {
    "@circuit/core": "0.0.0",
    "@circuit/x402": "0.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
