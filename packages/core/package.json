{
  "name": "@circuit-llm/core",
  "version": "0.2.8",
  "description": "Circuit SDK core — http client, injectable config, ed25519 identity, shared types.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node --experimental-strip-types --conditions=development --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Circuit-LLM/circuit-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Circuit-LLM/circuit-sdk/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Circuit-LLM/circuit-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
