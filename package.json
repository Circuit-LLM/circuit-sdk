{
  "name": "circuit-sdk",
  "version": "0.2.4",
  "private": true,
  "description": "Circuit SDK \u2014 TypeScript toolkit for the Circuit decentralized-LLM ecosystem: x402-paid inference, data, wallet, and hosted agents with non-custodial signing. See the README and docs/.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "cli": "node apps/cli/bin/circuit.js",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "jayson": {
      "uuid": "^11.1.1"
    },
    "esbuild": "^0.28.1"
  }
}
